# MikoPBX REST API Test Configuration
# Copy this file to .env and configure for your environment

# ============================================================================
# API Configuration (Required)
# ============================================================================

# MikoPBX REST API URL
# Examples:
#   - Local Docker: http://localhost:8189/pbxcore/api/v3
#   - Remote VM:    http://192.168.1.100:8081/pbxcore/api/v3
#   - Cloud:        https://mikopbx.example.com/pbxcore/api/v3
MIKOPBX_API_URL=http://localhost:8189/pbxcore/api/v3

# API Credentials
MIKOPBX_API_USERNAME=admin
MIKOPBX_API_PASSWORD=123456789MikoPBX#1

# ============================================================================
# Execution Mode Configuration
# ============================================================================

# Execution mode: docker|api|ssh|local (auto-detected if not set)
# - docker: Local Docker container (docker exec)
# - api:    Remote via REST API (system:executeBashCommand)
# - ssh:    Remote via SSH
# - local:  Direct local execution
# Leave empty for auto-detection
#MIKOPBX_EXECUTION_MODE=

# Docker container name (used when execution_mode=docker or auto-detected)
MIKOPBX_CONTAINER=mikopbx_tests-refactoring

# SSH configuration (used when execution_mode=ssh)
# Set MIKOPBX_SSH_HOST to force SSH mode
#MIKOPBX_SSH_HOST=192.168.1.100
#MIKOPBX_SSH_USER=root
#MIKOPBX_SSH_PORT=22

# ============================================================================
# Database Paths (inside container/VM)
# ============================================================================

# Main SQLite database path
#MIKOPBX_DB_PATH=/cf/conf/mikopbx.db

# CDR SQLite database path
#MIKOPBX_CDR_DB_PATH=/storage/usbdisk1/mikopbx/astlogs/asterisk/cdr.db

# ============================================================================
# Storage Paths (inside container/VM)
# ============================================================================

# Storage root path
#MIKOPBX_STORAGE_PATH=/storage/usbdisk1/mikopbx

# Call recordings path
#MIKOPBX_MONITOR_PATH=/storage/usbdisk1/mikopbx/astspool/monitor

# Log files path
#MIKOPBX_LOG_PATH=/storage/usbdisk1/mikopbx/log

# ============================================================================
# Test Configuration
# ============================================================================

# Enable CDR database seeding before tests (1=enabled, 0=disabled)
ENABLE_CDR_SEED=1

# Enable CDR cleanup after tests (1=enabled, 0=disabled)
ENABLE_CDR_CLEANUP=1

# Enable system reset before tests (1=enabled, 0=disabled)
# WARNING: This will restore factory defaults!
ENABLE_SYSTEM_RESET=0

# ============================================================================
# Deployment Scenarios
# ============================================================================

# LOCAL DOCKER (default)
# - Uses docker exec to run commands inside local container
# - Fastest for development
# MIKOPBX_API_URL=http://localhost:8189/pbxcore/api/v3
# MIKOPBX_CONTAINER=mikopbx_php83
# (execution_mode auto-detects as 'docker')

# REMOTE VM/SERVER (via REST API)
# - Uses REST API system:executeBashCommand for all operations
# - No Docker or SSH required on test runner
# - Recommended for CI/CD and cloud deployments
# MIKOPBX_API_URL=http://192.168.1.100:8081/pbxcore/api/v3
# (execution_mode auto-detects as 'api')

# REMOTE VM/SERVER (via SSH)
# - Uses SSH to execute commands
# - Alternative to REST API when SSH access is available
# MIKOPBX_API_URL=http://192.168.1.100:8081/pbxcore/api/v3
# MIKOPBX_SSH_HOST=192.168.1.100
# MIKOPBX_SSH_USER=root
# (execution_mode auto-detects as 'ssh' or force with MIKOPBX_EXECUTION_MODE=ssh)

# CLOUD DEPLOYMENT
# - MikoPBX running in cloud (AWS, Azure, GCP, etc.)
# - Tests run from local machine or CI/CD runner
# - Uses REST API only (no Docker or SSH)
# MIKOPBX_API_URL=https://mikopbx.example.com/pbxcore/api/v3
# MIKOPBX_API_USERNAME=admin
# MIKOPBX_API_PASSWORD=SecurePassword123!
# (execution_mode auto-detects as 'api')
