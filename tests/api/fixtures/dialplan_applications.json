{
  "echo.test": {
    "name": "Echo Test Application",
    "extension": "2300108",
    "type": "self::TYPE_PLAINTEXT",
    "applicationlogic": "1,NoOp(Echo test started)\nn,Answer()\nn,Echo()\nn,Hangup()",
    "uniqid": "APP-ECHO-001",
    "description": "Simple echo test for audio verification"
  },
  "time.announcement": {
    "name": "Time Announcement",
    "extension": "2300109",
    "type": "self::TYPE_PLAINTEXT",
    "applicationlogic": "1,Answer()\nn,Wait(1)\nn,SayUnixTime(,EST5EDT,IMp)\nn,Playback(vm-goodbye)\nn,Hangup()",
    "uniqid": "APP-TIME-001",
    "description": "Announces current time to caller"
  },
  "weather.service": {
    "name": "Weather Information",
    "extension": "2300110",
    "type": "self::TYPE_PHP_AGI",
    "applicationlogic": "<?php\n// Weather service AGI script\nrequire_once \"phpagi.php\";\n$agi = new AGI();\n\n$agi->answer();\n$agi->stream_file(\"welcome\");\n$agi->say_digits(\"123\");\n$agi->hangup();\n?>",
    "uniqid": "APP-WEATHER-001",
    "description": "Weather information service using PHP AGI"
  },
  "callback.service": {
    "name": "Callback Service",
    "extension": "2300111",
    "type": "self::TYPE_PLAINTEXT",
    "applicationlogic": "1,Answer()\nn,Read(CALLBACK_NUMBER,please-enter-your-callback-number,10,,,3,10)\nn,NoOp(Callback requested to ${CALLBACK_NUMBER})\nn,Playback(thank-you)\nn,Hangup()",
    "uniqid": "APP-CALLBACK-001",
    "description": "Allows callers to request a callback"
  },
  "voicemail.check": {
    "name": "Voicemail Check",
    "extension": "2300112",
    "type": "self::TYPE_PLAINTEXT",
    "applicationlogic": "1,Answer()\nn,VoiceMailMain(${CALLERID(num)}@default)\nn,Hangup()",
    "uniqid": "APP-VM-001",
    "description": "Direct voicemail access for users"
  },
  "conference.info": {
    "name": "Conference Information",
    "extension": "2300113",
    "type": "self::TYPE_PLAINTEXT",
    "applicationlogic": "1,Answer()\nn,Playback(conference-info)\nn,Playback(for-sales-press-1)\nn,Playback(for-support-press-2)\nn,WaitExten(5)\nn,Hangup()",
    "uniqid": "APP-CONFINFO-001",
    "description": "Provides conference room information"
  },
  "directory.service": {
    "name": "Company Directory",
    "extension": "2300114",
    "type": "self::TYPE_PLAINTEXT",
    "applicationlogic": "1,Answer()\nn,Directory(default,default,f)\nn,Hangup()",
    "uniqid": "APP-DIR-001",
    "description": "Company directory by name"
  },
  "music.on.hold.test": {
    "name": "Music On Hold Test",
    "extension": "2300115",
    "type": "self::TYPE_PLAINTEXT",
    "applicationlogic": "1,Answer()\nn,MusicOnHold(default,30)\nn,Hangup()",
    "uniqid": "APP-MOH-001",
    "description": "Tests music on hold for 30 seconds"
  },
  "call.recording.test": {
    "name": "Call Recording Test",
    "extension": "2300116",
    "type": "self::TYPE_PLAINTEXT",
    "applicationlogic": "1,Answer()\nn,Playback(this-call-may-be-monitored-or-recorded)\nn,MixMonitor(test-${UNIQUEID}.wav)\nn,Echo()\nn,StopMixMonitor()\nn,Hangup()",
    "uniqid": "APP-REC-001",
    "description": "Tests call recording functionality"
  },
  "emergency.announcement": {
    "name": "Emergency Announcement",
    "extension": "2300117",
    "type": "self::TYPE_PLAINTEXT",
    "applicationlogic": "1,Answer()\nn,Playback(emergency-announcement)\nn,Playback(please-standby)\nn,Wait(5)\nn,Goto(main-ivr,s,1)",
    "uniqid": "APP-EMRG-001",
    "description": "Emergency announcement system"
  }
}
