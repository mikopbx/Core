# EditorConfig — https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{js,jsx,ts,tsx}]
indent_size = 4

[*.{json,json5}]
indent_size = 2

[*.volt]
indent_size = 4

[*.{sh,bash}]
indent_size = 4

[Makefile]
indent_style = tab
