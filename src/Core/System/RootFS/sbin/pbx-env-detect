# Environment detection script for MikoPBX
# Usage: pbx-env-detect [option]
# Options:
#   -t, --type        Return environment type (docker, vmware, vbox, kvm, qemu, xen, baremetal)
#   -s, --serial      Return available serial ports
#   -c, --console     Return console device
#   -r, --arch        Return CPU architecture (x86_64, aarch64, armv7l, etc)
#   -a, --all         Return all environment information

# Cache file for environment detection
ENV_CACHE="/etc/.pbx_env_info"
ENV_CHECK_AGE=3600  # Re-check every hour

# Parse command line options
OPTION="type"
NO_CACHE=0
while [ $# -gt 0 ]; do
    case "$1" in
        -t|--type)
            OPTION="type"
            ;;
        -s|--serial)
            OPTION="serial"
            ;;
        -c|--console)
            OPTION="console"
            ;;
        -r|--arch)
            OPTION="arch"
            ;;
        -a|--all)
            OPTION="all"
            ;;
        --nocache)
            NO_CACHE=1
            ;;
        *)
            echo "Unknown option: $1" >&2
            echo "Usage: $0 [-t|--type] [-s|--serial] [-c|--console] [-r|--arch] [-a|--all] [--nocache]" >&2
            exit 1
            ;;
    esac
    shift
done

# Function to detect environment type
detect_environment() {
    # Check for Docker
    if [ -f "/.dockerenv" ] || [ -n "$DOCKER_CONTAINER" ]; then
        echo "docker"
        return
    fi

    # Check for LXC via environment variable
    if [ -n "$container" ] && [ "$container" = 'lxc' ]; then
        echo "lxc"
        return
    fi

    # Fallback: check init process environment for LXC
    # Needed when shell doesn't inherit the container env var (e.g., via shell_exec from PHP)
    if [ -r "/proc/1/environ" ]; then
        if grep -qz "container=lxc" /proc/1/environ 2>/dev/null; then
            echo "lxc"
            return
        fi
    fi

    # Check for virtualization using various methods

    # Method 1: Check DMI/SMBIOS information
    if [ -r "/sys/devices/virtual/dmi/id/sys_vendor" ]; then
        SYS_VENDOR=$(cat /sys/devices/virtual/dmi/id/sys_vendor 2>/dev/null | tr '[:upper:]' '[:lower:]')
        SYS_PRODUCT=$(cat /sys/devices/virtual/dmi/id/product_name 2>/dev/null | tr '[:upper:]' '[:lower:]')

        case "$SYS_VENDOR" in
            *vmware*)
                echo "vmware"
                return
                ;;
            *innotek*|*virtualbox*)
                echo "vbox"
                return
                ;;
            *qemu*)
                # Distinguish between QEMU and KVM
                if grep -q "kvm" /proc/cpuinfo 2>/dev/null || [ -e "/dev/kvm" ]; then
                    echo "kvm"
                else
                    echo "qemu"
                fi
                return
                ;;
            *xen*)
                echo "xen"
                return
                ;;
        esac

        # Check product name for QEMU
        case "$SYS_PRODUCT" in
            *qemu*)
                if grep -q "kvm" /proc/cpuinfo 2>/dev/null || [ -e "/dev/kvm" ]; then
                    echo "kvm"
                else
                    echo "qemu"
                fi
                return
                ;;
        esac
    fi
    
    # Method 2: Check for hypervisor
    if [ -r "/sys/hypervisor/type" ]; then
        HYPERVISOR=$(cat /sys/hypervisor/type 2>/dev/null | tr '[:upper:]' '[:lower:]')
        case "$HYPERVISOR" in
            xen)
                echo "xen"
                return
                ;;
        esac
    fi
    
    # Method 3: Check CPU flags for virtualization
    if [ -r "/proc/cpuinfo" ]; then
        if grep -q "hypervisor" /proc/cpuinfo 2>/dev/null; then
            # Try to determine if it's QEMU by checking model name
            MODEL_NAME=$(grep "model name" /proc/cpuinfo 2>/dev/null | head -n1 | tr '[:upper:]' '[:lower:]')
            case "$MODEL_NAME" in
                *qemu*)
                    if grep -q "kvm" /proc/cpuinfo 2>/dev/null || [ -e "/dev/kvm" ]; then
                        echo "kvm"
                    else
                        echo "qemu"
                    fi
                    return
                    ;;
            esac
            # We're virtualized, but couldn't determine the type
            echo "virtual"
            return
        fi
    fi
    
    # Method 4: Check for specific files/directories
    if [ -d "/proc/xen" ]; then
        echo "xen"
        return
    fi
    
    # Method 5: Check loaded modules
    if [ -r "/proc/modules" ]; then
        if grep -q "vboxguest" /proc/modules 2>/dev/null; then
            echo "vbox"
            return
        fi
        if grep -q "vmw_balloon" /proc/modules 2>/dev/null; then
            echo "vmware"
            return
        fi
    fi

    # Method 6: Check dmesg for DMI info (useful during early boot when sysfs may not be ready)
    DMESG_DMI=$(/bin/dmesg 2>/dev/null | /bin/grep -i "DMI:" | head -n1 | tr '[:upper:]' '[:lower:]')
    if [ -n "$DMESG_DMI" ]; then
        case "$DMESG_DMI" in
            *qemu*)
                if [ -e "/dev/kvm" ]; then
                    echo "kvm"
                else
                    echo "qemu"
                fi
                return
                ;;
            *vmware*)
                echo "vmware"
                return
                ;;
            *virtualbox*)
                echo "vbox"
                return
                ;;
        esac
    fi

    # If we get here, assume bare metal
    echo "baremetal"
}

# Function to detect CPU architecture
detect_architecture() {
    # Method 1: Use uname -m (most reliable)
    if command -v uname >/dev/null 2>&1; then
        ARCH=$(uname -m 2>/dev/null)
        if [ -n "$ARCH" ]; then
            echo "$ARCH"
            return
        fi
    fi

    # Method 2: Check /proc/cpuinfo
    if [ -r "/proc/cpuinfo" ]; then
        # For ARM systems, check CPU architecture field
        CPU_ARCH=$(grep "CPU architecture" /proc/cpuinfo 2>/dev/null | head -n1 | awk '{print $3}')
        if [ -n "$CPU_ARCH" ]; then
            case "$CPU_ARCH" in
                8)
                    echo "aarch64"
                    return
                    ;;
                7)
                    echo "armv7l"
                    return
                    ;;
                6)
                    echo "armv6l"
                    return
                    ;;
            esac
        fi

        # For x86 systems, check flags
        if grep -q "lm" /proc/cpuinfo 2>/dev/null; then
            echo "x86_64"
            return
        elif grep -q "flags" /proc/cpuinfo 2>/dev/null; then
            echo "i686"
            return
        fi
    fi

    # Method 3: Check for architecture-specific files
    if [ -d "/lib64" ] || [ -d "/usr/lib64" ]; then
        echo "x86_64"
        return
    fi

    # Fallback
    echo "unknown"
}

# Function to detect available serial ports
detect_serial_ports() {
    SERIAL_PORTS=""
    
    # Skip serial port detection in Docker
    ENV_TYPE=$(detect_environment)
    if [ "$ENV_TYPE" = "docker" ]; then
        echo ""
        return
    fi
    
    # Check for serial ports
    for i in 0 1 2 3 4 5; do
        DEV="/dev/ttyS$i"
        # Check if device exists and is character device
        if [ -c "$DEV" ] && [ -w "$DEV" ]; then
            # Try to write a null byte to verify it's really available
            if echo -n "" > "$DEV" 2>/dev/null; then
                if [ -z "$SERIAL_PORTS" ]; then
                    SERIAL_PORTS="$DEV"
                else
                    SERIAL_PORTS="$SERIAL_PORTS $DEV"
                fi
            fi
        fi
    done
    
    echo "$SERIAL_PORTS"
}

# Function to detect console device
detect_console() {
    # Default console
    CONSOLE="/dev/console"
    
    # Check if we have a proper console
    if [ -c "$CONSOLE" ] && [ -r "$CONSOLE" ] && [ -w "$CONSOLE" ]; then
        echo "$CONSOLE"
    else
        # Fallback to null device
        echo "/dev/null"
    fi
}

# Function to get cached or fresh environment info
get_env_info() {
    # Check if cache exists and is recent (skip if --nocache)
    if [ "$NO_CACHE" -eq 0 ] && [ -f "$ENV_CACHE" ]; then
        CACHE_AGE=$(($(date +%s) - $(stat -c %Y "$ENV_CACHE" 2>/dev/null || echo 0)))
        if [ "$CACHE_AGE" -lt "$ENV_CHECK_AGE" ]; then
            cat "$ENV_CACHE"
            return
        fi
    fi

    # Generate fresh environment info
    ENV_TYPE=$(detect_environment)
    SERIAL_PORTS=$(detect_serial_ports)
    CONSOLE=$(detect_console)
    ARCH=$(detect_architecture)

    # Save to cache (skip if --nocache)
    if [ "$NO_CACHE" -eq 0 ] && [ -n "$ENV_TYPE" ]; then
        cat > "$ENV_CACHE" << EOF
ENV_TYPE=$ENV_TYPE
SERIAL_PORTS=$SERIAL_PORTS
CONSOLE=$CONSOLE
ARCH=$ARCH
EOF
    fi

    # Return current values
    cat << EOF
ENV_TYPE=$ENV_TYPE
SERIAL_PORTS=$SERIAL_PORTS
CONSOLE=$CONSOLE
ARCH=$ARCH
EOF
}

# Main execution
case "$OPTION" in
    type)
        get_env_info | grep "^ENV_TYPE=" | cut -d'=' -f2
        ;;
    serial)
        get_env_info | grep "^SERIAL_PORTS=" | cut -d'=' -f2
        ;;
    console)
        get_env_info | grep "^CONSOLE=" | cut -d'=' -f2
        ;;
    arch)
        get_env_info | grep "^ARCH=" | cut -d'=' -f2
        ;;
    all)
        get_env_info
        ;;
esac

exit 0