# Guard against duplicate Asterisk instances.
# Monit calls this as its start program for Asterisk.
#
# When 'core restart now' is executed from Asterisk CLI, Asterisk
# re-execs itself with a new PID. Monit detects the old PID as dead
# and tries to start another instance — causing two Asterisk processes
# fighting over ports, leaking PJSIP threads, and eventually OOM.
#
# This script checks if Asterisk is already running before starting,
# preventing the duplicate instance.
#
# Deployed as part of rootfs. Referenced by monit config
# generated in PbxConf::generateMonitConf().
#

PIDFILE="/var/asterisk/run/asterisk.pid"

if [ -f "$PIDFILE" ]; then
    PID=$(cat "$PIDFILE" 2>/dev/null)
    if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
        logger -t safe_asterisk_start "Asterisk already running (PID $PID), skip"
        exit 0
    fi
fi

rm -f "$PIDFILE"

# Raise file descriptor limit for high call volume (default 1024 limits ~160 calls)
# Each call uses ~4-8 FDs (SIP sockets + RTP ports)
ulimit -n 65535

exec /usr/sbin/asterisk -F
