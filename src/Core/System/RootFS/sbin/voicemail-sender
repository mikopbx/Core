#!/usr/bin/php
<?php

use MikoPBX\Common\Models\Extensions;
use MikoPBX\Core\Asterisk\Configs\VoiceMailConf;
use MikoPBX\Core\System\BeanstalkClient;
use MikoPBX\Core\System\Configs\SoundFilesConf;
use MikoPBX\Core\System\SystemMessages;
use MikoPBX\Core\System\Util;
use MikoPBX\Core\Workers\WorkerCallEvents;
use MikoPBX\Common\Models\PbxSettings;
use MikoPBX\Core\System\Mail\Builders\VoicemailNotificationBuilder;
use MikoPBX\Core\System\Mail\NotificationQueueHelper;

require_once('Globals.php');

$linkedId = $argv[1] ?? '';
if (empty($linkedId)) {
    SystemMessages::sysLogMsg('Voicemail-Sender', 'Script called without linkedId, exiting', LOG_ERR);
    exit(1);
}

$endTime = Util::getNowDate();
$toMails = VoiceMailConf::getToMail($linkedId);

try {
    // Read piped email from Asterisk with timeout to prevent hanging
    $stdinStream = fopen("php://stdin", 'rb');
    if ($stdinStream === false) {
        throw new RuntimeException('Failed to open php://stdin');
    }
    stream_set_blocking($stdinStream, false);

    $rawEmail = '';
    $deadline = microtime(true) + 5.0;
    while (microtime(true) < $deadline) {
        $read = [$stdinStream];
        $write = $except = null;
        $ready = stream_select($read, $write, $except, 0, 200000);

        if ($ready === false) {
            break;
        }

        if ($ready > 0) {
            $chunk = fread($stdinStream, 65536);
            if ($chunk === false || $chunk === '') {
                break;
            }
            $rawEmail .= $chunk;
        } elseif (feof($stdinStream)) {
            break;
        }
    }
    fclose($stdinStream);

    if (empty($rawEmail)) {
        throw new RuntimeException('No data received from stdin (timeout 5s)');
    }

    $parser = new PhpMimeMailParser\Parser();
    $parser->setText($rawEmail);
    unset($rawEmail);

    $headerDate = $parser->getHeader('date');
    $d = DateTime::createFromFormat('D, d M Y H:i:s O', $headerDate);
    if ($d === false) {
        throw new RuntimeException('Failed to parse email date header: ' . $headerDate);
    }

    $file = implode('', $parser->saveAttachments('/tmp/'));
    $inboxPath = VoiceMailConf::getCopyFilename($file, $linkedId, $d->getTimestamp(), true);
    // CDR recording path — the final .webm file in INBOX (WorkerWav2Webm will convert it)
    $recordingFile = Util::trimExtensionForFile($inboxPath) . '.webm';

    // Convert attachment to mp3 for email notification
    $emailAttachment = '';
    $result = SoundFilesConf::convertAudioFile(
        $file,
        ['mp3'],
        [
            'normalize' => true,
            'use_cache' => false,
            'force' => true,
            'bitrate' => '16k'
        ]
    );

    if ($result['success'] && isset($result['formats']['mp3']['path'])) {
        $mp3File = $result['formats']['mp3']['path'];
        if (file_exists($mp3File)) {
            $emailAttachment = $mp3File;
        } else {
            SystemMessages::sysLogMsg('Voicemail-Sender', "MP3 file not found after conversion: {$mp3File}", LOG_ERR);
        }
    } else {
        $errorMsg = $result['error'] ?? 'unknown';
        SystemMessages::sysLogMsg('Voicemail-Sender', "MP3 conversion failed: {$errorMsg}", LOG_ERR);
    }

    // Clean up original attachment
    if (file_exists($file)) {
        unlink($file);
    }

    // Build recipient list from voicemail config and email headers
    $addresses   = mailparse_rfc822_parse_addresses($parser->getHeader('to'));
    $rawHeaderTo = $addresses[0]['address'] ?? '';
    if (!empty($rawHeaderTo)) {
        $toMails[] = $rawHeaderTo;
    }

    $emailBody = str_replace(['"', '%|%'], ["'", '"'], $parser->getMessageBody());
    $params    = json_decode($emailBody, true, 512, JSON_THROW_ON_ERROR);
    foreach ($params as $key => $value) {
        if ($key === 'VM_DATE') {
            $params[$key] = $d->format("Y-m-d H:i:s");
        } elseif ($key === 'VM_CALLERID') {
            $value = str_replace("'", '"', $value);
            $data = mailparse_rfc822_parse_addresses($value);
            $params['VM_CALLER_NAME'] = $data[0]['display'] ?? '';
            $params['VM_CALLER_NUM']  = $data[0]['address'] ?? '';
            unset($data);
        }
    }

    $cidName = $params['VM_CALLER_NAME'] ?? '';
    if (empty($cidName)) {
        $params['VM_CALLER_NAME'] = Extensions::getCidByPhoneNumber($params['VM_CALLER_NUM']);
    }

    // Queue notifications for async sending via WorkerNotifyByEmail
    $recipients = array_unique($toMails);
    foreach ($recipients as $recipient) {
        $builder = new VoicemailNotificationBuilder();
        $builder->setRecipient($recipient)
                ->setCallerId($params['VM_CALLER_NUM'] ?? '')
                ->setCallerName($params['VM_CALLER_NAME'] ?? '')
                ->setMailbox($params['VM_MAILBOX'] ?? '')
                ->setMessageNumber($params['VM_MSGNUM'] ?? '')
                ->setDuration($params['VM_DUR'] ?? '')
                ->setMessageDate($params['VM_DATE'] ?? '')
                ->setRecordingFile($emailAttachment);

        NotificationQueueHelper::queueOrSend(
            $builder,
            async: true,
            priority: NotificationQueueHelper::PRIORITY_LOW
        );

        SystemMessages::sysLogMsg(
            'Voicemail-Sender',
            sprintf('Queued voicemail notification for: %s (attachment: %s)', $recipient, $emailAttachment),
            LOG_INFO
        );
    }

    // MP3 file is NOT deleted here — WorkerNotifyByEmail cleans up after sending
} catch (Throwable $e) {
    $recordingFile = '';
    SystemMessages::sysLogMsg('Voicemail-Sender', $e->getMessage(), LOG_ERR);
}

$data = [
    'action'           => 'voicemail_end',
    'linkedid'         => $linkedId,
    'vm-recordingfile' => $recordingFile,
    'endtime'          => $endTime,
];

$client = new BeanstalkClient(WorkerCallEvents::class);
$client->publish(json_encode($data, JSON_THROW_ON_ERROR));

$manager = Util::getAstManager();
unset($data['action']);
$manager->UserEvent('voicemail_end', $data);
