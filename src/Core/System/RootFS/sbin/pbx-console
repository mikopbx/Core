# Function to display the help message
display_help() {
    echo "Usage: $0 <subcommand> [options]"
    echo
    echo "Subcommands:"
    echo "  services <action>   Manage PBX services"
    echo "    - stop-all         Stop all PBX services"
    echo "    - start-all        Start all PBX services"
    echo "    - restart-all      Restart all PBX services"
    echo "    - status           Show status of all PBX workers"
    echo "  service <name>      Kill a specific PBX service"
    echo "  debug <name> <ip>   Debug a specific script"
    echo "  xdebug <action> <ip>   Debug whole system"
    echo "    - enable-cli        Start CLI scripts debug session"
    echo "    - enable-www        Start WEB scripts debug session"
    echo "    - enable-agi        Start Asterisk scripts debug session"
    echo "  cron <action>       Manage cron"
    echo "    - stop             Stop cron"
    echo "    - restart          Restart cron"
    echo "    - start            Start cron"
    echo "    - show             Show the status of cron"
    echo
    echo "Examples:"
    echo "  $0 services start-all"
    echo "  $0 service php-worker"
    echo "  $0 debug WorkerApiCommands 192.168.1.2"
    echo "  $0 debug WorkerApiCommands docker.for.mac.localhost"
    echo "  $0 cron show"
    echo "  $0 xdebug enable-www docker.for.mac.localhost"
    echo "  $0 xdebug enable-agi 192.168.1.2"
    echo
}

# Check if help is requested or no subcommand provided
if [ "$1" = "help" ] || [ -z "$1" ]; then
    display_help
    exit 0
fi

# First command line argument is treated as a subcommand
subcmd=$1;

# Direct path to WorkerSafeScriptsCore
safeScript="/usr/www/src/Core/Workers/Cron/WorkerSafeScriptsCore.php";

# Case switch for the subcommand
case "${subcmd}" in
services)
   # Second command line argument is treated as an action
   action=$2;
   # Case switch for the action when subcommand is services
   case "${action}" in
   stop-all)
      echo 'Stopping all PBX services.';
      # Get all worker PIDs including instances (e.g., WorkerApiCommands-1, WorkerApiCommands-2)
      # Look for PHP processes containing Worker class names
      pids=$(ps -A -o pid,args | grep -E '/usr/bin/php.*Worker[A-Za-z]+\.php' | grep -v grep | awk '{print $1}');

      # If PIDs exist, send SIGUSR1 first for graceful shutdown
      if [ -n "${pids}" ]; then
        echo "Sending graceful shutdown signal to workers: ${pids}";
        for pid in ${pids}; do
          kill -USR1 ${pid} 2>/dev/null || true;
        done
        
        # Wait a bit for graceful shutdown
        sleep 3;
        
        # Force kill any remaining processes
        remaining=$(ps -A -o pid,args | grep -E '/usr/bin/php.*Worker[A-Za-z]+\.php' | grep -v grep | awk '{print $1}');
        if [ -n "${remaining}" ]; then
          echo "Force stopping remaining workers: ${remaining}";
          for pid in ${remaining}; do
            kill -TERM ${pid} 2>/dev/null || true;
          done
        fi
        echo 'All PBX services stopped.';
      else
        echo 'No PBX services running.';
      fi
      ;;
   start-all)
     # If safe script exists, start it
     if [ -f "$safeScript" ]; then
       echo 'Starting all PBX services via WorkerSafeScriptsCore.';
       /usr/bin/php -f "$safeScript" start > /dev/null 2>&1
       echo 'PBX services started.';
     else
        echo "Safe script not found at: ${safeScript}";
     fi
     ;;
   restart-all)
     # If safe script exists, restart it
     if [ -f "$safeScript" ]; then
       echo 'Restarting all PBX services via WorkerSafeScriptsCore.';
       /usr/bin/php -f "$safeScript" restart > /dev/null 2>&1
       echo 'PBX services restarted.';
     else
        echo "Safe script not found at: ${safeScript}";
     fi
     ;;
   status)
     echo 'PBX Workers Status:';
     echo '==================';
     # Get all PHP worker processes with details
     ps -A -o pid,ppid,args | grep -E '/usr/bin/php.*Worker[A-Za-z]+\.php' | grep -v grep | while read line; do
       pid=$(echo "$line" | awk '{print $1}');
       ppid=$(echo "$line" | awk '{print $2}');
       # Extract worker name from the command line
       worker=$(echo "$line" | grep -oE 'Worker[A-Za-z]+\.php' | sed 's/\.php//');
       # Check for instance ID
       instance=$(echo "$line" | grep -oE -- '--instance-id=[0-9]+' | cut -d= -f2);
       if [ -z "$instance" ]; then
         echo "PID: ${pid} PPID: ${ppid} Worker: ${worker}";
       else
         echo "PID: ${pid} PPID: ${ppid} Worker: ${worker} Instance: ${instance}";
       fi
     done
     
     # Count workers
     total=$(ps -A -o pid,args | grep -E '/usr/bin/php.*Worker[A-Za-z]+\.php' | grep -v grep | wc -l);
     echo "==================";
     echo "Total workers running: ${total}";
     ;;
  esac
  ;;
service)
  serviceName=$2;
  
  # Handle worker instance numbers (e.g. WorkerApiCommands-1, WorkerApiCommands-2)
  # Look for exact worker class name or with instance suffix
  pids=$(ps -A -o pid,args | grep -E "php.*${serviceName}\.php" | grep -v grep | grep -v "$0" | awk '{print $1}');

  # If PIDs exist, kill the service
  if [ -n "${pids}" ]; then
    echo "Stopping PBX service ${serviceName}.";
    echo "Found PIDs: ${pids}";
    
    # Try graceful shutdown first
    for pid in ${pids}; do
      echo "Sending SIGUSR1 to PID ${pid}";
      kill -USR1 ${pid} 2>/dev/null || true;
    done
    
    # Wait a bit for graceful shutdown
    sleep 2;
    
    # Check if processes are still running
    remaining=$(ps -A -o pid,args | grep -E "php.*${serviceName}\.php" | grep -v grep | grep -v "$0" | awk '{print $1}');
    if [ -n "${remaining}" ]; then
      echo "Force stopping remaining processes: ${remaining}";
      for pid in ${remaining}; do
        kill -TERM ${pid} 2>/dev/null || true;
      done
    fi
    
    echo "PBX service ${serviceName} stopped.";
  else
    echo "PBX service ${serviceName} not running.";
  fi
  ;;
debug)
  # Prepare for debugging specific script passed as second argument
  pbxConsole="$0";
  scriptName="$2";
  ipDebugger="$3";

  # Find the file to debug
  pathToFile=$(find /usr/www/src/ -name "${scriptName}.php")
  if [ ! -f "$pathToFile" ]; then
    echo "File ${scriptName}.php not found.";
    exit 2;
  fi

  # Stop cron and specific service
  echo "Stopping cron and ${scriptName} for debug...";
  "${pbxConsole}" cron stop;
  "${pbxConsole}" service "${scriptName}";

  # Configure xdebug environment variable for PHP
  # Adjusted for Xdebug 3
  export XDEBUG_CONFIG="client_host=${ipDebugger} client_port=9003"
  export XDEBUG_MODE="debug"
  export XDEBUG_SESSION=1

  # Enable xdebug in PHP if it's not enabled
  if [ ! -f /etc/php.d/15-xdebug.ini ]; then
    echo "Creating Xdebug configuration file..."
    cat <<EOL > /etc/php.d/15-xdebug.ini
zend_extension=xdebug.so
xdebug.mode=debug
xdebug.start_with_request=yes
xdebug.client_host=${ipDebugger}
xdebug.client_port=9003
EOL
  else
    echo "Updating Xdebug client_host to ${ipDebugger}..."
    sed -i "s/^xdebug\.client_host=.*/xdebug.client_host=${ipDebugger}/" /etc/php.d/15-xdebug.ini
  fi

  # Start the PHP script with xdebug enabled
  php -dxdebug.mode=debug -dxdebug.start_with_request=yes -f "$pathToFile" start;
  ;;

xdebug)
    # Handle actions related to xdebug
    pbxConsole="$0";
    action=$2;
    ipDebugger="$3";
    case "${action}" in
      enable-cli)
        echo "Enabling Xdebug for CLI..."
        if [ -f /etc/php.d/15-xdebug.ini ]; then
          echo "Updating Xdebug client_host to ${ipDebugger}..."
          sed -i "s/^xdebug\.client_host=.*/xdebug.client_host=${ipDebugger}/" /etc/php.d/15-xdebug.ini
        else
          echo "Creating Xdebug configuration file..."
          cat <<EOL > /etc/php.d/15-xdebug.ini
zend_extension=xdebug.so
xdebug.mode=debug
xdebug.start_with_request=yes
xdebug.client_host=${ipDebugger}
xdebug.client_port=9003
EOL
        fi
        echo "Done"
        ;;
      enable-www)
        echo "Enabling Xdebug for WWW..."
        if [ -f /etc/php.d/15-xdebug.ini ]; then
          echo "Updating Xdebug client_host to ${ipDebugger}..."
          sed -i "s/^xdebug\.client_host=.*/xdebug.client_host=${ipDebugger}/" /etc/php.d/15-xdebug.ini
        else
          echo "Creating Xdebug configuration file..."
          cat <<EOL > /etc/php.d/15-xdebug.ini
zend_extension=xdebug.so
xdebug.mode=debug
xdebug.start_with_request=yes
xdebug.client_host=${ipDebugger}
xdebug.client_port=9003
EOL
        fi
        echo "Restarting php-fpm..."
        killall php-fpm
        sleep 5;
        php-fpm -c /etc/php.ini
        echo "Done"
        ;;
      enable-agi)
        echo "Enabling Xdebug for AGI..."
        echo "Restarting the Asterisk daemon..."
        "${pbxConsole}" xdebug enable-cli ${ipDebugger}
        monit restart asterisk
        echo "Done"
        ;;
    esac
    ;;
cron)
  # Handle actions related to cron
  action=$2;
  case "${action}" in
    stop)
      # If cron is running, kill it
      ps | grep -v grep | grep crond > /dev/null;
      result=$?;
      if [ "$result" = "0" ]; then
        echo 'Killing cron.';
        killall crond;
      else
        echo 'Cron not started.';
      fi
      ;;
    restart)
       # Stop cron and then start it
      "${pbxConsole}" cron stop;
      echo 'Starting cron.';
      /usr/sbin/crond -L /dev/null -l 8
      ;;
    start)
      # If cron is not running, start it
      ps | grep -v grep | grep crond > /dev/null;
      result=$?;
      if [ "$result" = "1" ]; then
        echo 'Starting cron.';
        /usr/sbin/crond -L /dev/null -l 8
      else
        echo 'Cron already started.';
      fi
      ;;
    show)
      # Show the status of cron
      ps | head -n 1;
      ps | grep crond | grep -v grep;
      ;;
  esac
  ;;
esac