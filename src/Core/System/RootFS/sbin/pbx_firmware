# Load shell functions for console/serial output
# Fallback for updates from older systems without shell_functions.sh
if [ -f /sbin/shell_functions.sh ]; then
    source /sbin/shell_functions.sh
else
    # Minimal inline implementation for compatibility with older MikoPBX versions
    # These functions will be used only when updating FROM versions that lack shell_functions.sh
    echo_info() {
        echo " - $1"
        # Try to output to serial if available
        if [ -c "/dev/ttyS0" ] && [ -w "/dev/ttyS0" ]; then
            echo " - $1" > /dev/ttyS0 2>/dev/null
        fi
    }
    echo_error() {
        echo "ERROR: $1"
        if [ -c "/dev/ttyS0" ] && [ -w "/dev/ttyS0" ]; then
            echo "ERROR: $1" > /dev/ttyS0 2>/dev/null
        fi
    }
fi

# Interactive pause before critical operations
# Allows user to cancel upgrade or enter manual shell for debugging
wait_for_user_input() {
    local message="${1:-Continuing with upgrade}"
    echo_info "$message"
    echo_info "Press 'c' to cancel, 'm' for manual shell, or wait 10 seconds..."
    local counter=10
    while [ $counter -gt 0 ]; do
        read -r -t 1 -n 1 input 2>/dev/null
        case "$input" in
            c|C)
                echo_info "Upgrade cancelled by user."
                touch /tmp/rebooting
                exit 1
                ;;
            m|M)
                echo_info "Entering manual shell. Type 'exit' to continue upgrade."
                echo_info "Available: gdisk, parted, sfdisk, lsblk, blkid, mount, dd, pv"
                /bin/sh
                echo_info "Continue upgrade? (y/n)"
                read -r -n 1 cont
                [ "$cont" != "y" ] && [ "$cont" != "Y" ] && exit 1
                return 0
                ;;
        esac
        echo -ne " - Continuing in $counter seconds...\033[0K\r"
        counter=$((counter - 1))
    done
    echo ""
}

# Assign input arguments to variables
img_file="$1";
systemDevice="$2"

# Inform the user of the firmware upgrade process
echo;
echo_info "Firmware upgrade in progress...";
echo_info "Backing up configuration...";

# Create a temporary directory to backup configuration
mkdir -p /tmp/configbak;

# Verify the MD5 hash of the compressed image file
md5Hash="$(/bin/gunzip -N -l < "${img_file}" | /bin/busybox grep -v uncompressed_name | /bin/busybox awk  '{ print $4}')";
if [ "$md5Hash" != "$(/bin/gunzip -c "${img_file}" |/bin/busybox md5sum | /bin/busybox cut -f 1 -d ' ')" ] ; then
    # Inform the user of the checksum mismatch and abort the update
    echo_error "The checksum of the system image does not match.";
    echo_error "Update was aborted...";
    rm -rf "$img_file";
    # Set a flag to indicate rebooting.
    touch /tmp/rebooting;
    exit 0;
else
    # Inform the user of successful checksum verification
    echo_info "Successful checksum verification! Start the system upgrade ...";
fi

# Check if the livecd file exists, and proceed with different operations depending on its existence
if [ -f /offload/livecd ]; then
  # Copy the configuration to the backup directory and unmount /conf.recover
  /bin/busybox cp -p /conf.recover/conf/* /tmp/configbak | /bin/busybox awk '{print "\t" $0}'
  echo_info "Unmounting /conf.recover partition...";
  /bin/umount -f /conf.recover;
else

  if [ -f /offload/version.buildtime ]; then
    # Offload is mounted
    # Backup of settings to a disk for data storage
    /sbin/dump-conf-db
  fi;
  # Copy the configuration to the tmp (RAM) directory
  echo_info "Backup the system settings to temporary directory...";
  /bin/busybox cp -Rv /cf/conf/* /tmp/configbak | /bin/busybox awk '{print "\t" $0}'

  mounted_storage=$(mount | /bin/busybox grep storage | /bin/busybox awk '{ print $1}');

  # Get the name of the mounted storage and the 4th partition (if it exists)
  partition4Name=$(/bin/lsblk -r | /bin/busybox grep "${systemDevice}" | /bin/busybox cut -d ' ' -f 1 | /bin/busybox grep "4$" | /bin/busybox sort -u)

  # If the 4th partition is not the same as the mounted storage
  if [ "/dev/${partition4Name}" != "${mounted_storage}" ]; then
    # Storage is on a separate disk. Proceed with the freeup, backup and update procedures
    /sbin/freestorage "doNotUnMount";

    # Define the backup directory and image path
    backupDir="$(cat /var/etc/storage_device)/mikopbx/backup/last-update-firmware"
    backupImg="$backupDir/system.img";
    rm -rf "$backupDir"; mkdir -p "$backupDir";

    # Copy the configuration to the storage and backup the system image
    echo_info "Backup system partition to storage ...";
    # Check for serial port using new method if available
    SERIAL_PORT=""
    if [ -x "/sbin/pbx-env-detect" ]; then
        SERIAL_PORTS=$(/sbin/pbx-env-detect --serial)
        if [ -n "$SERIAL_PORTS" ]; then
            SERIAL_PORT=$(echo $SERIAL_PORTS | cut -d' ' -f1)
        fi
    elif [ -c "/dev/ttyS0" ] && [ -w "/dev/ttyS0" ] && echo -n "" > /dev/ttyS0 2>/dev/null; then
        SERIAL_PORT="/dev/ttyS0"
    fi
    
    if [ -n "$SERIAL_PORT" ]; then
        /bin/pv -p "/dev/${systemDevice}" | /bin/gzip | dd of="$backupImg" bs=4M 2>&1 | /bin/busybox tee $SERIAL_PORT >/dev/null
    else
        /bin/pv -p "/dev/${systemDevice}" | /bin/gzip | dd of="$backupImg" bs=4M >/dev/null 2>&1
    fi
  else
    # Storage is on the main disk which needs to be unmounted, so move the image to RAM
    echo_info "Moving the update img to RAM before storage will be unmounted ..."
    tmp_img=$(/bin/busybox basename "$1");
    img_file="/tmp/${tmp_img}";

    # Move the img file to /tmp because storage will be unmounted
    src_file=$(/bin/readlink -f "$1")
    if [ "${src_file}" != "${img_file}" ]; then
      mv "${src_file}" "${img_file}";
    fi

     # Free up the storage
    echo_info "Umount storage partition ...";
    /sbin/freestorage;
  fi

  # Unmount the main disk
  /sbin/freeupoffload;
fi

# Inform the user of the installation process
DISK="/dev/${systemDevice}";
if [ -r "${img_file}" ]; then
  if /sbin/parted -s "${DISK}" print 2> /dev/null | /bin/busybox awk '{$1=$1; print}' | /bin/busybox grep -w '^4' > /dev/null; then
    partitionFour=$(/bin/lsblk -r "$DISK" -p -o NAME,TYPE | /bin/busybox grep "part$" | /bin/busybox cut -d ' ' -f 1 | /bin/busybox grep "4$");
  else
    partitionFour=''
  fi

  # Allow user to enter manual shell before critical partition operations
  wait_for_user_input "About to start partition operations on $DISK"

  if command -v gdisk >/dev/null 2>&1 && [ -n "$partitionFour" ]; then
    # If the 4th section is missing,
    # then markup conversion is not required,
    # there is no risk of data loss.
    PARTITION_TYPE=$(/sbin/parted --script "$DISK" print 2>/dev/null | /bin/busybox grep "Partition Table" | /bin/busybox awk '{print $3}');
    echo_info "Performing an action for the $PARTITION_TYPE section";
    if [ "$PARTITION_TYPE" == "msdos" ]; then
      echo_info "At the end of the 4th partition ($partitionFour), 1 Mb of free space will be required...";
      REDUCE_BY=1
      LAST_ENTRY=$(parted -s "$DISK" unit MiB print free 2>/dev/null | tail -n 1)
      FREE_SPACE=$(echo "$LAST_ENTRY" | /bin/busybox awk '{print $3}' | /bin/busybox grep -o '[0-9]*')
      if [[ (-z "$FREE_SPACE" || "$FREE_SPACE" -lt "$REDUCE_BY") && -n "$partitionFour" ]]; then
      	e2fsck -f -y "$partitionFour";
        echo_info "Reducing the 4th section...";
        SECTOR_SIZE=$(blockdev --getss "$DISK")
      	SECTORS_IN_MIB=$((1024 * 1024 / SECTOR_SIZE))
      	sfdisk -d "$DISK" 2> /dev/null > disk_layout.txt
      	CURRENT_SIZE=$(/bin/busybox grep "^$partitionFour" disk_layout.txt | /bin/busybox grep -o 'size=[ ]*[0-9]*' | /bin/busybox tr -d ' ' | cut -d= -f2)
      	NEW_SIZE=$((CURRENT_SIZE - REDUCE_BY * SECTORS_IN_MIB))
      	NEW_SIZE_MIB=$((CURRENT_SIZE / SECTORS_IN_MIB - 1))
        sed -i "s|^\($partitionFour.*size=\s*\)[0-9]*\(.*\)$|\1$NEW_SIZE\2|" disk_layout.txt
      	sfdisk "$DISK"  > /dev/null 2>&1 < disk_layout.txt
      	rm disk_layout.txt;
      	/sbin/resize2fs "$partitionFour" "$NEW_SIZE_MIB"M 2> /dev/null > /dev/null;
      fi
      echo_info "Converting markup to GPT."
      echo -e "w\nY\n" | /bin/gdisk "$DISK" > /dev/null;
      resultGDisk="$?";
      if [ "$resultGDisk" -eq 0 ]; then
        echo_info "The conversion to GPT has been completed successfully."
      else
        echo_error "Converting to GPT."
      fi
    fi
  fi

  part4Action='create';
  if [ -n "$partitionFour" ]; then
    export FS_BACKUP_PART4=fs-backup-part4.img;
    echo_info "Start backup fs $FS_BACKUP_PART4 super block for part4 ($partitionFour)"
    dd if="$partitionFour" of="$FS_BACKUP_PART4" bs=1M count=1 >/dev/null 2>&1;
    part4Action='update';
  fi

  echo_info "Installing new image on $DISK"
  # Check for serial port using new method if available
  SERIAL_PORT=""
  if [ -x "/sbin/pbx-env-detect" ]; then
      SERIAL_PORTS=$(/sbin/pbx-env-detect --serial)
      if [ -n "$SERIAL_PORTS" ]; then
          SERIAL_PORT=$(echo $SERIAL_PORTS | cut -d' ' -f1)
      fi
  elif [ -c "/dev/ttyS0" ] && [ -w "/dev/ttyS0" ] && echo -n "" > /dev/ttyS0 2>/dev/null; then
      SERIAL_PORT="/dev/ttyS0"
  fi
  
  if [ -n "$SERIAL_PORT" ]; then
    /bin/pv -p "${img_file}" | /bin/gunzip | dd of="$DISK" bs=4M 2>&1 | /bin/busybox tee $SERIAL_PORT >/dev/null
  else
    /bin/pv -p "${img_file}" | /bin/gunzip | dd of="$DISK" bs=4M >/dev/null 2>&1;
  fi
  resultPv="$?";
  echo_info "result install code $resultPv";
  /sbin/blockdev --rereadpt "$DISK" > /dev/null 2>&1;

  # Fix GPT backup table location after writing smaller image to larger disk
  # The backup GPT header must be at the end of the disk, not at original image size
  if [ -x /bin/sgdisk ]; then
    echo_info "Relocating GPT backup header to end of disk..."
    sgdiskOutput=$(/bin/sgdisk -e "$DISK" 2>&1)
    sgdiskResult=$?
    echo_info "sgdisk exit code: $sgdiskResult"
    [ -n "$sgdiskOutput" ] && echo "$sgdiskOutput" | while read line; do echo_info "sgdisk: $line"; done
  else
    echo_error "sgdisk not available to fix backup header!"
  fi

  /sbin/blockdev --rereadpt "$DISK" > /dev/null 2>&1;
  sleep 3;

  # If the pv command fails or there aren't four partitions, restore the system image from the backup
  if [ ! "$resultPv" = '0' ] || [ ! "$(/bin/lsblk -l "$DISK" | /bin/busybox grep -c part)" = '4' ]; then
    if [ -f "$backupImg" ]; then
      echo_error "There are some errors, restoring system from backup to /dev/${systemDevice}"
      # Check for serial port using new method if available
      SERIAL_PORT=""
      if [ -x "/sbin/pbx-env-detect" ]; then
          SERIAL_PORTS=$(/sbin/pbx-env-detect --serial)
          if [ -n "$SERIAL_PORTS" ]; then
              SERIAL_PORT=$(echo $SERIAL_PORTS | cut -d' ' -f1)
          fi
      elif [ -c "/dev/ttyS0" ] && [ -w "/dev/ttyS0" ] && echo -n "" > /dev/ttyS0 2>/dev/null; then
          SERIAL_PORT="/dev/ttyS0"
      fi
      
      if [ -n "$SERIAL_PORT" ]; then
        /bin/pv -p "$backupImg" | /bin/gunzip | dd of="$DISK" bs=4M 2>&1 | /bin/busybox tee $SERIAL_PORT >/dev/null
      else
        /bin/pv -p "$backupImg" | /bin/gunzip | dd of="$DISK" bs=4M >/dev/null 2>&1;
      fi
    fi;
  fi;
  rm -rf "$backupImg";
  echo_info "The execution of the dd command was finished...";

  # Update the partition table
  /sbin/initial_storage_part_four "$part4Action" "$DISK";
  echo_info "Check if it necessary to $part4Action 4-th storage partition. The result is ${?}...";
fi

# Reread the partition table of the system device
/sbin/blockdev --rereadpt "$DISK" > /dev/null 2>&1
sleep 3;

# Get the name of the 3rd partition
partition3Name=$(/bin/lsblk -r -p | /bin/busybox grep "${systemDevice}" | /bin/busybox cut -d ' ' -f 1 | /bin/busybox grep "3$" | /bin/busybox sort -u)

# If the livecd file exists, re-mount /conf.recover, restore configuration, and reboot the system
if [ -f /offload/livecd ]; then
  echo_info "Re-mounting /conf.recover partition with read/write mode..."
  /bin/mount -w -o noatime "${partition3Name}" /conf.recover | /bin/busybox awk '{print "\t" $0}'
  rm -f /conf.recover/conf/*
  echo_info "Restoring the MikoPBX default configuration ..."
  /bin/busybox cp -pv /tmp/configbak/* /conf.recover/conf/ | /bin/busybox awk '{print "\t" $0}'
  touch /tmp/ejectcd
else
  # Format the 3rd partition and mount it as /cf. Then, copy the configuration back and remove the image file
  echo_info "Formating the 3rd partition (${partition3Name}) and mount it as /cf folder ...";
  /sbin/mkfs.ext4 -qF "${partition3Name}" | /bin/busybox awk '{print "\t" $0}'
  sleep 3;
  /bin/mount -w -o noatime "${partition3Name}" /cf | /bin/busybox awk '{print "\t" $0}'
  mkdir -p /cf/conf
  echo_info "Restoring the MikoPBX configuration settings...";
  /bin/busybox cp -Rv /tmp/configbak/* /cf/conf/ | /bin/busybox awk '{print "\t" $0}'

  echo_info "Deleting firmware image...";
  rm -rf "${img_file}";
fi

echo_info "Reboot pending. Cancel with 'touch /tmp/cancel_rebooting'"
# Waiting timeout
WAIT_TIME=10
counter=0
while [ $counter -lt $WAIT_TIME ]; do
    if [ -f /tmp/cancel_rebooting ]; then
        # Flag file was deleted
        echo_info "System reboot was cancelled"
        exit 0
    fi
    sleep 1
    counter=$((counter+1))
done

echo_info "Rebooting the system..."
/sbin/pbx_reboot;