require_once 'Globals.php';

use MikoPBX\Core\System\Configs\NginxConf;

// Check command line arguments
if ($argc !== 3) {
    echo "Usage: {$argv[0]} <ban|unban> <IP>\n";
    exit(1);
}

$action = $argv[1];
$ip = $argv[2];

// Validate action
if (!in_array($action, ['ban', 'unban'])) {
    echo "Invalid action. Use 'ban' or 'unban'\n";
    exit(1);
}

// Validate IP address
if (!filter_var($ip, FILTER_VALIDATE_IP)) {
    echo "Invalid IP address: $ip\n";
    exit(1);
}

// Call the NginxConf static method for fail2ban actions
try {
    NginxConf::fail2banNginxAction($action, $ip);
    exit(0);
} catch (Exception $e) {
    echo "Error: " . $e->getMessage() . "\n";
    exit(1);
}