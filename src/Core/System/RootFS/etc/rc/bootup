namespace MikoPBX\Core\RootFS\etc\rc;
use MikoPBX\Core\System\{Processes, Util, SystemLoader, System};

require_once('Globals.php');

// Mark system as booting IMMEDIATELY to prevent race condition with pbx_init/console_menu
// pbx_init is started in parallel via inittab and checks isBooting() before Redis is ready
System::setBooting(true);

// Record system boot start time using monotonic clock (hrtime)
// This avoids issues with NTP time synchronization during boot
$bootStartTime = hrtime(true);
file_put_contents('/tmp/system_boot_start_time', $bootStartTime);

// Sleep if /tmp/ejectcd file exists
if(file_exists('/tmp/ejectcd')){
    sleep(15);
}

// Create an instance of SystemLoader and start the system
$mikoPBX = new SystemLoader();
$result = $mikoPBX->startSystem();

// Run /etc/rc/bootup_pbx synchronously to show progress on console
// Previously used mwExecBg but that lost output to /dev/null
if((true === $result)
    && ! Util::isRecoveryMode()
    && ! System::isContainer()
) {
    // Bare-metal only: run bootup_pbx directly
    Processes::mwExec('/etc/rc/bootup_pbx');
} elseif (! System::isContainer()) {
    // Clear booting flag only for Recovery Mode on bare-metal
    // Containers (Docker/LXC) call bootup_pbx separately via ContainerEntrypoint
    System::setBooting(false);
}