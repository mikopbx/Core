server {
    listen      <WEBPort>;
    server_name   default;
    resolver <DNS>;

    add_header 'Access-Control-Allow-Origin' '*' always;
    include mikopbx/security-headers.conf;

    # locations files
    include mikopbx/locations/*.conf;

 	# module locations files
    include mikopbx/modules_locations/*.conf;
}